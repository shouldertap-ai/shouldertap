# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# --- LLM provider (litellm is provider-agnostic; set whichever key matches shouldertap.yaml's llm.model) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# --- HTTP API auth (the single static bearer token consumers/CLI/MCP use to call the engine) ---
SHOULDERTAP_API_TOKEN=
